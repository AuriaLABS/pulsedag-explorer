# Use "live" to call PulseDAG or "mock" for the deterministic local fixture.
VITE_DATA_MODE=live

# Browser-facing read-only gateway. The Vite dev server proxies /rpc to PULSEDAG_RPC_TARGET.
VITE_API_BASE_URL=/rpc
VITE_POLL_INTERVAL_MS=15000

# Server-side development proxy target. Keep the node RPC bound to loopback.
PULSEDAG_RPC_TARGET=http://127.0.0.1:8080
